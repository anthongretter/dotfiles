// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent": {
    "always_allow_tool_actions": true,
    "default_profile": "ask",
    "model_parameters": [],
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4"
    }
  },
  "buffer_font_family": "JetBrains Mono",
  "base_keymap": "JetBrains",
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "soft_wrap": "editor_width",
  "ui_font_family": "JetBrains Mono",
  "ui_font_size": 15,
  "buffer_font_size": 16,
  "experimental.theme_overrides": {
    "background.appearance": "blurred",
    "background": "#000000b0",
    "editor.background": "#00000009",
    "editor.gutter.background": "#00000009",
    "tab_bar.background": "#00000009",
    "terminal.background": "#00000000",
    "toolbar.background": "#00000009",
    "tab.active_background": "#28282809",
    "tab.inactive_background": "#00000009",
    "status_bar.background": "#000000c0",
    "title_bar.background": "#000000f0",
    "panel.background": "#000000ff",
    "border.variant": "#00000000",
    "scrollbar.track.border": "#00000000",
    "editor.active_line.background": "#00000000"
  },
  "theme": {
    "mode": "system",
    "light": "Github Dark",
    "dark": "One Dark"
  },
  "autosave": { "after_delay": { "milliseconds": 500 } }
}
