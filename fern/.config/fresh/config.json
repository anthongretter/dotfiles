{
  "version": 2,
  "theme": "terminal",
  "lsp": {
    "python": {
      "enabled": true,
      "auto_start": true,
      "process_limits": {
        "max_memory_percent": 50,
        "max_cpu_percent": 90,
        "enabled": true
      }
    }
  },
  "plugins": {
    "vi_mode": {
      "enabled": true,
      "settings": {
        "autoStart": false
      }
    }
  }
}