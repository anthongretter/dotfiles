{
  "layer": "top",
  "position": "top",

  "modules-left": ["hyprland/workspaces", "tray", "custom/mpris"],
  "modules-center": ["clock"],
  "modules-right": ["wireplumber", "cpu", "memory", "network#wifi", "network#anchor", "network#vpn"],

  "hyprland/workspaces": {
