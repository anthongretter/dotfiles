* {
    font-family: "JetBrains Mono";
    font-size: 14px;
}

window#waybar {
    /* Mapped from Xresources background #000000 */
    background-color: #000000;
    /* Mapped from Xresources foreground #ffffff */
    color: #ffffff;
}

.modules-left {
    /* Mapped from Xresources background #000000 */
    background-color: #000000;
    padding: 0px 0px 0px 0px;
}

.modules-right {
    /* Mapped from Xresources background #000000 */
    background-color: #000000;
    padding: 0px 5px 0px 0px;
}

#custom-scratch {
    /* Mapped from Xresources background #000000 */
    background-color: #000000;
    /* Mapped from Xresources color13 #50ff3d */
    color: #50ff3d;
    padding: 0px 9px 0px 9px;
}

#workspaces {
}

#workspaces button {
    padding: 0px 11px 0px 11px;
    min-width: 1px;
    /* Mapped from Xresources color8 #03260f */
    color: #ffffff;
}

#workspaces button.focused {
    padding: 0px 11px 0px 11px;
    /* Mapped from Xresources color0 #1e1e1e */
    background-color: #1e1e1e;
    /* Mapped from Xresources foreground #ffffff */
    color: #50ff3d;
}

#window {
    /* Mapped from Xresources foreground #ffffff */
    color: #ffffff;
    /* Mapped from Xresources background #000000 */
    background-color: #000000;
    padding: 0px 10px 0px 10px;
}

window#waybar.empty #window {
    background-color: transparent;
    color: transparent;
}

window#waybar.empty {
    /* Mapped from Xresources background #000000 */
    background-color: #000000;
}

#network,
#temperature,
#backlight,
#pulseudio,
#battery,
#cpu,
#memory {
    padding: 0px 15px 0px 15px;
    /* Mapped from Xresources foreground #ffffff */
    color: #ffffff;
}

#clock {
    margin: 0px 15px 0px 15px;
    /* Mapped from Xresources foreground #ffffff */
    color: #ffffff;
}

#tray {
    padding: 0px 8px 0px 5px;
    margin: 0px 5px 0px 5px;
}

#battery.critical {
    /* Mapped from Xresources color1 #fb0029 */
    color: #fb0029;
}

#network.disconnected {
    /* Mapped from Xresources color1 #fb0029 */
    color: #fb0029;
}

#network.wifi {
    /* Mapped from Xresources color6 #2bb767 */
    color: #2bb767;
}
